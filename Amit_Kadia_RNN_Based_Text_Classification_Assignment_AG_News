able even without gradient clipping\n","- Performance is similar to the earlier LSTM model\n","\n","Conclusion:\n","- For this dataset and architecture, gradient instability is not a major issue\n","- The model is able to converge effectively without clipping"],"metadata":{"id":"mPe9YSvLP-QO"}},{"cell_type":"code","source":["# Rebuild model\n","lstm_clip = Sequential([\n","    Embedding(input_dim=vocab_size, output_dim=128),\n","    LSTM(64),\n","    Dense(64, activation='relu'),\n","    Dense(4, activation='softmax')\n","])\n","\n","lstm_clip.build(input_shape=(None, max_length))\n","\n","# Compile WITH gradient clipping\n","lstm_clip.compile(\n","    loss='categorical_crossentropy',\n","    optimizer=Adam(clipnorm=1.0),\n","    metrics=['accuracy']\n",")\n","\n","# Train\n","history_clip = lstm_clip.fit(\n","    train_padded,\n","    train_labels_cat,\n","    epochs=5,\n","    batch_size=128,\n","    validation_split=0.2\n",")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ay2wkpGi6n86","executionInfo":{"status":"ok","timestamp":1777299325885,"user_tz":-330,"elapsed":750529,"user":{"displayName":"Amit Kadia","userId":"00743091928818247073"}},"outputId":"f5c84bbc-ae43-4336-b00d-0b85f7045e88"},"execution_count":28,"outputs":[{"output_type":"stream","name":"stdout","text":["Epoch 1/5\n","\u001b[1m750/750\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m154s\u001b[0m 201ms/step - accuracy: 0.2522 - loss: 1.3859 - val_accuracy: 0.2349 - val_loss: 1.3856\n","Epoch 2/5\n","\u001b[1m750/750\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m149s\u001b[0m 199ms/step - accuracy: 0.2541 - loss: 1.3844 - val_accuracy: 0.2350 - val_loss: 1.3852\n","Epoch 3/5\n","\u001b[1m750/750\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m149s\u001b[0m 199ms/step - accuracy: 0.6193 - loss: 0.8108 - val_accuracy: 0.8914 - val_loss: 0.3282\n","Epoch 4/5\n","\u001b[1m750/750\u001b[0m \u001b[